{
  "schemaTemplates": {
    "article": {
      "description": "Primary schema for blog posts",
      "template": {
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": "[ARTICLE TITLE]",
        "description": "[META DESCRIPTION - UNDER 155 CHARS]",
        "image": "[FEATURED IMAGE URL]",
        "author": {
          "@type": "Person",
          "name": "Marky Tantongco",
          "url": "https://financialprotectionadvocate.ph",
          "jobTitle": "Licensed Non-Life Insurance Agent",
          "worksFor": {
            "@type": "Organization",
            "name": "Financial Protection Advocate"
          }
        },
        "publisher": {
          "@type": "Organization",
          "name": "Financial Protection Advocate",
          "logo": {
            "@type": "ImageObject",
            "url": "[LOGO URL]"
          }
        },
        "datePublished": "[YYYY-MM-DD]",
        "dateModified": "[YYYY-MM-DD]",
        "mainEntityOfPage": {
          "@type": "WebPage",
          "@id": "[ARTICLE URL]"
        }
      }
    },
    "faqPage": {
      "description": "FAQ schema for People Also Ask optimization",
      "template": {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "[QUESTION 1]",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "[ANSWER 1 - 40-60 WORDS]"
            }
          },
          {
            "@type": "Question",
            "name": "[QUESTION 2]",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "[ANSWER 2 - 40-60 WORDS]"
            }
          },
          {
            "@type": "Question",
            "name": "[QUESTION 3]",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "[ANSWER 3 - 40-60 WORDS]"
            }
          },
          {
            "@type": "Question",
            "name": "[QUESTION 4]",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "[ANSWER 4 - 40-60 WORDS]"
            }
          },
          {
            "@type": "Question",
            "name": "[QUESTION 5]",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "[ANSWER 5 - 40-60 WORDS]"
            }
          }
        ]
      }
    },
    "person": {
      "description": "Author entity schema for E-E-A-T",
      "template": {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Marky Tantongco",
        "alternateName": "Financial Protection Advocate",
        "description": "IC Philippines licensed non-life insurance agent specializing in health insurance comparison and consultation for self-employed Filipinos, OFW families, and SME owners.",
        "url": "https://financialprotectionadvocate.ph",
        "image": "[AUTHOR PHOTO URL]",
        "jobTitle": "Licensed Non-Life Insurance Agent",
        "worksFor": {
          "@type": "Organization",
          "name": "Financial Protection Advocate"
        },
        "knowsAbout": [
          "Health Insurance Philippines",
          "HMO Philippines",
          "Pacific Cross Philippines",
          "Non-Life Insurance",
          "Insurance Commission Philippines"
        ],
        "sameAs": [
          "https://facebook.com/financialprotectionadvocate",
          "https://instagram.com/markytanky"
        ]
      }
    },
    "localBusiness": {
      "description": "Business schema for local SEO",
      "template": {
        "@context": "https://schema.org",
        "@type": "InsuranceAgency",
        "name": "Financial Protection Advocate",
        "description": "Licensed non-life insurance agent in the Philippines specializing in health insurance comparison and consultation.",
        "url": "https://financialprotectionadvocate.ph",
        "telephone": "[PHONE NUMBER]",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "[CITY]",
          "addressRegion": "[PROVINCE]",
          "addressCountry": "PH"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": "[LATITUDE]",
          "longitude": "[LONGITUDE]"
        },
        "openingHours": "Mo-Fr 09:00-18:00",
        "priceRange": "$$",
        "image": "[BUSINESS LOGO URL]",
        "sameAs": [
          "https://facebook.com/financialprotectionadvocate",
          "https://instagram.com/markytanky"
        ]
      }
    },
    "breadcrumbList": {
      "description": "Breadcrumb schema for navigation",
      "template": {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://financialprotectionadvocate.ph"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "[CATEGORY NAME]",
            "item": "https://financialprotectionadvocate.ph/[CATEGORY SLUG]"
          },
          {
            "@type": "ListItem",
            "position": 3,
            "name": "[ARTICLE TITLE]",
            "item": "[ARTICLE URL]"
          }
        ]
      }
    },
    "service": {
      "description": "Service schema for insurance consultation",
      "template": {
        "@context": "https://schema.org",
        "@type": "Service",
        "serviceType": "Insurance Consultation",
        "provider": {
          "@type": "Person",
          "name": "Marky Tantongco",
          "jobTitle": "Licensed Non-Life Insurance Agent"
        },
        "areaServed": {
          "@type": "Country",
          "name": "Philippines"
        },
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Insurance Services",
          "itemListElement": [
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Health Insurance Comparison"
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "HMO Consultation"
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "OFW Family Protection Planning"
              }
            }
          ]
        }
      }
    }
  },
  "combinedExample": {
    "description": "Example: Full schema implementation for a blog post",
    "template": "<script type=\"application/ld+json\">\n[\n  {\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"Article\",\n    \"headline\": \"Pacific Cross FlexiShield Review: Is It Worth It for Self-Employed Filipinos?\",\n    \"description\": \"Complete Pacific Cross health insurance review with pricing, network size, and honest pros/cons for self-employed Filipinos.\",\n    \"author\": {\n      \"@type\": \"Person\",\n      \"name\": \"Marky Tantongco\"\n    },\n    \"datePublished\": \"2024-01-15\",\n    \"dateModified\": \"2024-01-15\"\n  },\n  {\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"FAQPage\",\n    \"mainEntity\": [\n      {\n        \"@type\": \"Question\",\n        \"name\": \"Is Pacific Cross a good health insurance provider?\",\n        \"acceptedAnswer\": {\n          \"@type\": \"Answer\",\n          \"text\": \"Pacific Cross is a legitimate IC Philippines-registered health insurance provider with flexible plans for self-employed Filipinos. They offer comprehensive coverage but practice premium loading after claims.\"\n        }\n      }\n    ]\n  },\n  {\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"BreadcrumbList\",\n    \"itemListElement\": [\n      {\n        \"@type\": \"ListItem\",\n        \"position\": 1,\n        \"name\": \"Home\",\n        \"item\": \"https://financialprotectionadvocate.ph\"\n      },\n      {\n        \"@type\": \"ListItem\",\n        \"position\": 2,\n        \"name\": \"Provider Reviews\",\n        \"item\": \"https://financialprotectionadvocate.ph/reviews\"\n      },\n      {\n        \"@type\": \"ListItem\",\n        \"position\": 3,\n        \"name\": \"Pacific Cross FlexiShield Review\"\n      }\n    ]\n  }\n]\n</script>"
  },
  "implementationNotes": [
    "Place JSON-LD in the <head> section of your page",
    "Multiple schemas can be combined in a JSON array",
    "Always validate schema using Google's Rich Results Test",
    "Update dateModified when editing content",
    "Include FAQPage schema for articles with 5+ Q&As"
  ]
}
